registry=https://registry.npmjs.org

# Use exact versions when adding packages (prevents ^ and ~ prefixes)
save-exact=true

# Engine strict mode
engine-strict=false

# pnpm-specific settings (npm will warn about these, which is expected)
auto-install-peers=false
strict-peer-dependencies=false
side-effects-cache=true
shamefully-hoist=true
node-linker=hoisted
