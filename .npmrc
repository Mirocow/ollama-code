registry=https://registry.npmjs.org

# pnpm-specific settings (honored by pnpm, ignored by npm)
# These ensure exact version matching and prevent floating dependencies

# Use exact versions when adding packages
save-exact=true

# Don't modify lockfile on install (CI mode)
# In pnpm: use --frozen-lockfile flag or set frozen-lockfile=true
# In npm: use npm ci instead of npm install

# Disable auto-install of peers to avoid unexpected dependencies
auto-install-peers=false

# Don't fail on peer dependency conflicts
strict-peer-dependencies=false

# Engine strict mode - fail if Node.js version doesn't match
engine-strict=false

# Side effects cache for faster installs
side-effects-cache=true

# Shamefully hoist for better compatibility with tools expecting node_modules
shamefully-hoist=true

# Node linker type - hoisted for better compatibility
node-linker=hoisted
