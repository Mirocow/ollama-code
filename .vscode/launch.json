{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Ollama Code CLI",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--inspect-brk", "scripts/start.js"],
      "console": "integratedTerminal",
      "env": {
        "DEBUG": "1",
        "OLLAMA_CODE_NO_RELAUNCH": "true"
      },
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug Ollama Code CLI (with args)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--inspect-brk", "scripts/start.js"],
      "args": ["${input:cliArgs}"],
      "console": "integratedTerminal",
      "env": {
        "DEBUG": "1",
        "OLLAMA_CODE_NO_RELAUNCH": "true"
      },
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug Current Test File",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vitest", "run", "--no-coverage", "${file}"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug Core Package",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/packages/core",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--inspect-brk", "--experimental-strip-types", "src/core/test-ollama-api.ts"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Attach to Process",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "address": "localhost",
      "localRoot": "${workspaceFolder}",
      "remoteRoot": null
    }
  ],
  "inputs": [
    {
      "id": "cliArgs",
      "type": "promptString",
      "description": "Enter CLI arguments"
    }
  ]
}
