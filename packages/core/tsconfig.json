{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "composite": true,
    "types": ["node", "vitest/globals"],
    "skipLibCheck": true
  },
  "include": ["index.ts", "src/**/*.ts", "src/**/*.json", "src/types/*.d.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
